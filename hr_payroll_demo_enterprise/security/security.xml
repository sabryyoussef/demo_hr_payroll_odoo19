<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="group_hr_payroll_demo_user" model="res.groups">
        <field name="name">Payroll Demo User</field>
        <field name="privilege_id" ref="hr_payroll.res_groups_privilege_payroll"/>
        <field name="sequence">30</field>
        <field name="implied_ids" eval="[(4, ref('hr.group_hr_user'))]"/>
    </record>

    <record id="group_hr_payroll_demo_manager" model="res.groups">
        <field name="name">Payroll Demo Manager</field>
        <field name="privilege_id" ref="hr_payroll.res_groups_privilege_payroll"/>
        <field name="sequence">40</field>
        <field name="implied_ids" eval="[(4, ref('group_hr_payroll_demo_user')), (4, ref('hr_payroll.group_hr_payroll_manager'))]"/>
    </record>

    <!-- Assign admin to the demo manager group via res.users to avoid
         the 'Invalid field users in res.groups' error in Odoo 19. -->
    <record id="base.user_admin" model="res.users">
        <field name="groups_id" eval="[(4, ref('group_hr_payroll_demo_manager'))]"/>
    </record>

    <record id="rule_hr_payroll_demo_bank_transfer_company" model="ir.rule">
        <field name="name">Payroll demo bank transfers by company</field>
        <field name="model_id" ref="model_hr_payroll_demo_bank_transfer"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('group_hr_payroll_demo_user'))]"/>
    </record>

    <record id="rule_hr_payroll_demo_mass_operation_company" model="ir.rule">
        <field name="name">Payroll demo mass operations by company</field>
        <field name="model_id" ref="model_hr_payroll_demo_mass_operation"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('group_hr_payroll_demo_user'))]"/>
    </record>
</odoo>
