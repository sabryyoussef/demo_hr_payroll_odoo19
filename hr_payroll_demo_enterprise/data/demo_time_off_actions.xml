<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Opens ALLNETWORKS time off without "Waiting for me" default filters (empty list in demo). -->
    <record id="action_hr_payroll_demo_time_off_all" model="ir.actions.act_window">
        <field name="name">ALLNETWORKS Time Off</field>
        <field name="res_model">hr.leave</field>
        <field name="view_mode">list,kanban,form,calendar</field>
        <field name="search_view_id" ref="hr_holidays.hr_leave_view_search_manager"/>
        <field name="context">{
            'hide_employee_name': 0,
        }</field>
        <field name="domain">[('employee_id.company_id', 'in', allowed_company_ids)]</field>
    </record>
</odoo>
