<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hr_payroll_demo_scenario_list" model="ir.ui.view">
        <field name="name">hr.payroll.demo.scenario.list</field>
        <field name="model">hr.payroll.demo.scenario</field>
        <field name="arch" type="xml">
            <list decoration-success="status == 'ready'" decoration-warning="status == 'needs_review'">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="scenario_type"/>
                <field name="employee_id"/>
                <field name="department_id"/>
                <field name="status" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="view_hr_payroll_demo_scenario_form" model="ir.ui.view">
        <field name="name">hr.payroll.demo.scenario.form</field>
        <field name="model">hr.payroll.demo.scenario</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="scenario_type"/>
                        <field name="status"/>
                        <field name="employee_id"/>
                        <field name="department_id"/>
                    </group>
                    <group string="Scenario">
                        <field name="description" nolabel="1"/>
                    </group>
                    <group string="Speaker Note">
                        <field name="speaker_note" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_hr_payroll_demo_scenario" model="ir.actions.act_window">
        <field name="name">Demo Scenarios</field>
        <field name="res_model">hr.payroll.demo.scenario</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="view_hr_payroll_demo_department_summary_list" model="ir.ui.view">
        <field name="name">hr.payroll.demo.department.summary.list</field>
        <field name="model">hr.payroll.demo.department.summary</field>
        <field name="arch" type="xml">
            <list>
                <field name="department_id"/>
                <field name="employee_count"/>
                <field name="monthly_gross"/>
                <field name="monthly_net"/>
                <field name="overtime_hours"/>
                <field name="attendance_violation_count"/>
                <field name="pending_leave_count"/>
                <field name="bank_transfer_amount"/>
            </list>
        </field>
    </record>

    <record id="view_hr_payroll_demo_department_summary_pivot" model="ir.ui.view">
        <field name="name">hr.payroll.demo.department.summary.pivot</field>
        <field name="model">hr.payroll.demo.department.summary</field>
        <field name="arch" type="xml">
            <pivot>
                <field name="department_id" type="row"/>
                <field name="employee_count" type="measure"/>
                <field name="monthly_gross" type="measure"/>
                <field name="monthly_net" type="measure"/>
                <field name="overtime_hours" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="action_hr_payroll_demo_department_summary" model="ir.actions.act_window">
        <field name="name">Department Payroll Summary</field>
        <field name="res_model">hr.payroll.demo.department.summary</field>
        <field name="view_mode">list,pivot,graph</field>
    </record>

    <record id="view_hr_payroll_demo_reconciliation_list" model="ir.ui.view">
        <field name="name">hr.payroll.demo.reconciliation.list</field>
        <field name="model">hr.payroll.demo.reconciliation</field>
        <field name="arch" type="xml">
            <list decoration-success="state == 'matched'" decoration-danger="state == 'exception'">
                <field name="name"/>
                <field name="date"/>
                <field name="payslip_run_id"/>
                <field name="bank_transfer_id"/>
                <field name="payroll_total"/>
                <field name="bank_statement_total"/>
                <field name="difference"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="action_hr_payroll_demo_reconciliation" model="ir.actions.act_window">
        <field name="name">Payroll Reconciliation Examples</field>
        <field name="res_model">hr.payroll.demo.reconciliation</field>
        <field name="view_mode">list,form,pivot,graph</field>
    </record>
</odoo>
