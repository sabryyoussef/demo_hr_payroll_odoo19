<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hr_payroll_demo_dashboard_form" model="ir.ui.view">
        <field name="name">hr.payroll.demo.dashboard.form</field>
        <field name="model">hr.payroll.demo.dashboard</field>
        <field name="arch" type="xml">
            <form create="0" delete="0">
                <header>
                    <button name="action_refresh_kpis" type="object" string="Refresh KPIs" class="btn-secondary"/>
                    <button name="action_generate_payroll" type="object" string="Generate Payroll" class="btn-primary"/>
                    <button name="action_validate_attendance" type="object" string="Validate Attendance"/>
                    <button name="action_approve_leaves" type="object" string="Approve Leaves"/>
                    <button name="action_create_bank_transfer" type="object" string="Create Bank Transfer"/>
                </header>
                <sheet>
                    <h1><field name="name" readonly="1"/></h1>
                    <group>
                        <group string="HR Operations">
                            <field name="employee_count"/>
                            <field name="department_count"/>
                            <field name="open_leave_count"/>
                            <field name="attendance_alert_count"/>
                        </group>
                        <group string="Payroll Operations">
                            <field name="payroll_batch_count"/>
                            <field name="draft_payslip_count"/>
                            <field name="pending_bank_transfer_count"/>
                            <field name="monthly_net_total"/>
                        </group>
                    </group>
                    <group string="Smart Navigation">
                        <button name="action_open_employees" type="object" string="Employees" class="oe_highlight"/>
                        <button name="action_open_payroll_batches" type="object" string="Payroll Batches"/>
                        <button name="action_open_attendance_alerts" type="object" string="Attendance Alerts"/>
                        <button name="action_open_bank_transfers" type="object" string="Bank Transfers"/>
                    </group>
                    <group>
                        <field name="last_refresh" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_hr_payroll_demo_dashboard" model="ir.actions.act_window">
        <field name="name">HR Payroll Demo Dashboard</field>
        <field name="res_model">hr.payroll.demo.dashboard</field>
        <field name="view_mode">form</field>
        <field name="res_id" ref="dashboard_allnetworks_payroll"/>
    </record>
</odoo>
