<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hr_payroll_demo_bank_transfer_list" model="ir.ui.view">
        <field name="name">hr.payroll.demo.bank.transfer.list</field>
        <field name="model">hr.payroll.demo.bank.transfer</field>
        <field name="arch" type="xml">
            <list decoration-success="state == 'reconciled'" decoration-warning="state in ('generated', 'approved', 'sent')" decoration-muted="state == 'cancelled'">
                <field name="name"/>
                <field name="batch_id"/>
                <field name="payment_date"/>
                <field name="line_count"/>
                <field name="total_amount"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="view_hr_payroll_demo_bank_transfer_form" model="ir.ui.view">
        <field name="name">hr.payroll.demo.bank.transfer.form</field>
        <field name="model">hr.payroll.demo.bank.transfer</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_generate_from_batch" type="object" string="Generate From Batch" class="btn-primary" invisible="state not in ('draft', 'generated')"/>
                    <button name="action_approve" type="object" string="Approve" class="btn-primary" invisible="state != 'generated'"/>
                    <button name="action_send_to_bank" type="object" string="Send to Bank" class="btn-primary" invisible="state != 'approved'"/>
                    <button name="action_mark_reconciled" type="object" string="Mark Reconciled" class="btn-primary" invisible="state != 'sent'"/>
                    <button name="action_cancel" type="object" string="Cancel" invisible="state in ('reconciled', 'cancelled')"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,generated,approved,sent,reconciled"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button type="object" name="action_generate_from_batch" class="oe_stat_button" icon="fa-refresh">
                            <field name="line_count" widget="statinfo" string="Lines"/>
                        </button>
                    </div>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="batch_id"/>
                            <field name="payment_date"/>
                            <field name="bank_journal_id"/>
                        </group>
                        <group>
                            <field name="total_amount"/>
                            <field name="account_move_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Payment Lines">
                            <field name="line_ids">
                                <list editable="bottom">
                                    <field name="employee_id"/>
                                    <field name="department_id"/>
                                    <field name="payslip_id"/>
                                    <field name="bank_account_id"/>
                                    <field name="amount"/>
                                    <field name="status" widget="badge"/>
                                    <field name="note"/>
                                </list>
                            </field>
                        </page>
                        <page string="Payment File Preview">
                            <field name="payment_file_preview" nolabel="1"/>
                        </page>
                        <page string="Reconciliation">
                            <field name="reconciliation_note" nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_hr_payroll_demo_bank_transfer_search" model="ir.ui.view">
        <field name="name">hr.payroll.demo.bank.transfer.search</field>
        <field name="model">hr.payroll.demo.bank.transfer</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="batch_id"/>
                <filter name="pending" string="Pending" domain="[('state', 'in', ('draft', 'generated', 'approved', 'sent'))]"/>
                <filter name="reconciled" string="Reconciled" domain="[('state', '=', 'reconciled')]"/>
                <group>
                    <filter name="group_state" string="Status" context="{'group_by': 'state'}"/>
                    <filter name="group_batch" string="Batch" context="{'group_by': 'batch_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_hr_payroll_demo_bank_transfer" model="ir.actions.act_window">
        <field name="name">Bank Transfers</field>
        <field name="res_model">hr.payroll.demo.bank.transfer</field>
        <field name="view_mode">list,form,pivot,graph</field>
        <field name="search_view_id" ref="view_hr_payroll_demo_bank_transfer_search"/>
    </record>
</odoo>
